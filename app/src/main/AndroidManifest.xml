            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name=".HoaAbilityActivity7"
            android:process=":hap7"
            android:exported="true"
            android:configChanges="orientation|keyboard|layoutDirection|screenSize|uiMode|smallestScreenSize|density"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name=".HoaAbilityActivity8"
            android:process=":hap8"
            android:exported="true"
            android:configChanges="orientation|keyboard|layoutDirection|screenSize|uiMode|smallestScreenSize|density"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <activity
            android:name=".HoaAbilityActivity9"
            android:process=":hap9"
            android:exported="true"
            android:configChanges="orientation|keyboard|layoutDirection|screenSize|uiMode|smallestScreenSize|density"
            android:windowSoftInputMode="adjustResize|stateHidden" />

        <service
            android:name=".hdc.HdcService"
            android:exported="true"
            android:foregroundServiceType="specialUse" />

    </application>

</manifest>
